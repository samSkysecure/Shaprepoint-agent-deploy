# ── Skysecure's own Entra App Registration (the SP used to deploy into customer subscriptions) ──
# This is the SAME app registration whose client ID becomes "microsoftAppId" / "msaAppId"
# inside the customer's Container App and Bot Service - it IS the shared bot identity.
SKYSECURE_APP_ID=
SKYSECURE_APP_SECRET=

# ── ACR (Skysecure's container registry holding agent images) ──
ACR_SERVER=agentsdeploytest.azurecr.io
ACR_USERNAME=
ACR_PASSWORD=

# ── Azure OpenAI (shared across all customers for now) ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── Default region for new deployments ──
DEFAULT_LOCATION=southindia

# ── Path to the ARM template files (mounted/copied alongside the app) ──
ARM_TEMPLATES_DIR=./arm-templates
